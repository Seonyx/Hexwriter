@model HexWriter.Web.Models.ViewModels.Account.LoginViewModel
@using System.Globalization
@{
    Layout = null;
    ViewBag.Title = "Sign In";
}
<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In - HexWriter</title>
    <link rel="icon" href="~/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="~/favicon.ico" sizes="48x48" />
    <link rel="apple-touch-icon" href="~/apple-touch-icon.png" />
    <meta name="theme-color" content="#232046" />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@600&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="~/Content/css/site.css" rel="stylesheet" />
    <link href="~/Content/css/admin.css" rel="stylesheet" />
</head>
<body class="login-body">
    <div class="login-container">
        <div class="login-card">
            <div class="login-header">
                <img src="~/Content/images/hexwriter-mark.svg" alt="Hexwriter" width="64" height="64" />
                <h1>HexWriter</h1>
                @Html.Partial("_LanguageSelector")
            </div>

            @using (Html.BeginForm("Login", "Account", FormMethod.Post, new { @class = "login-form" }))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "alert alert-error" })

                <div class="form-group">
                    @Html.LabelFor(m => m.Username)
                    @Html.TextBoxFor(m => m.Username, new { @class = "form-control", placeholder = "Username", autofocus = "autofocus", autocomplete = "username" })
                    @Html.ValidationMessageFor(m => m.Username, "", new { @class = "field-validation-error" })
                </div>

                <div class="form-group">
                    @Html.LabelFor(m => m.Password)
                    @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Password", autocomplete = "current-password" })
                    @Html.ValidationMessageFor(m => m.Password, "", new { @class = "field-validation-error" })
                </div>

                <button type="submit" class="btn btn-primary btn-block">Sign In</button>
            }
        </div>
    </div>
</body>
</html>
