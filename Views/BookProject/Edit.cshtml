@model HexWriter.Web.Models.ViewModels.BookEditor.BookProjectViewModel
@using HexWriter.Web.Models.ViewModels.Admin
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Edit Project - " + Model.ProjectName;
    var bookUsers  = ViewBag.BookUsers  as List<BookUserAccessViewModel>;
    var bookGroups = ViewBag.BookGroups as List<BookGroupAccessViewModel>;
    var allUsers   = ViewBag.AllUsers   as List<GrantUserAccessViewModel>;
    var allGroups  = ViewBag.AllGroups  as List<GrantGroupAccessViewModel>;
}

@section Styles {
    <link href="~/Content/css/book-editor.css" rel="stylesheet" />
}

<div class="page-header">
    <h1>Edit Project: @Model.ProjectName</h1>
    <div>
        <a href="@Url.Action("Index")" class="btn btn-secondary">Back to Projects</a>
        <a href="/admin/bookeditor/characters/Index?bookProjectId=@Model.BookProjectID" class="btn btn-secondary">Characters</a>
    </div>
</div>

@using (Html.BeginForm("Edit", "BookProject", FormMethod.Post, new { @class = "admin-form" }))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.BookProjectID)

    <div class="form-group">
        @Html.LabelFor(m => m.ProjectName)
        @Html.TextBoxFor(m => m.ProjectName, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.ProjectName, "", new { @class = "text-danger" })
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.Author)
        @Html.TextBoxFor(m => m.Author, new { @class = "form-control", placeholder = "e.g. Steve Avis" })
        @Html.ValidationMessageFor(m => m.Author, "", new { @class = "text-danger" })
    </div>

    <div class="form-group">
        <label>
            @Html.CheckBoxFor(m => m.IsActive) Active
        </label>
    </div>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a href="@Url.Action("Index")" class="btn btn-secondary">Cancel</a>
    </div>
}

<hr />

<h2>Cover Image</h2>
@if (!string.IsNullOrEmpty(Model.CoverImagePath))
{
    <div class="current-cover" style="margin-bottom: 1rem;">
        <p>Current cover image is set.</p>
    </div>
}

@using (Html.BeginForm("UploadCover", "BookProject", new { id = Model.BookProjectID }, FormMethod.Post, new { enctype = "multipart/form-data", @class = "admin-form" }))
{
    @Html.AntiForgeryToken()

    <div class="form-group">
        <label for="coverImage">Upload Cover Image (JPG, PNG, or GIF)</label>
        <input type="file" name="coverImage" id="coverImage" accept=".jpg,.jpeg,.png,.gif" class="form-control" />
    </div>

    <div class="form-actions">
        <button type="submit" class="btn btn-secondary">Upload Cover</button>
    </div>
}

<hr />

<h2>Access</h2>

<h3>User Access</h3>
@if (bookUsers != null)
{
    <table class="table table-sm">
        <thead><tr><th>User</th><th>Display Name</th><th>Level</th><th>Granted</th><th></th></tr></thead>
        <tbody>
            @foreach (var bu in bookUsers)
            {
                <tr>
                    <td>@bu.Username</td>
                    <td>@bu.DisplayName</td>
                    <td>@bu.AccessLevel</td>
                    <td>@bu.GrantedAt.ToString("MMM d, yyyy")</td>
                    <td>
                        @using (Html.BeginForm("RevokeUserAccess", "BookProject", new { id = Model.BookProjectID, bookUserId = bu.BookUserId }, FormMethod.Post, new { style = "display:inline" }))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger btn-xs">Revoke</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<h4>Grant User Access</h4>
@using (Html.BeginForm("GrantUserAccess", "BookProject", new { id = Model.BookProjectID }, FormMethod.Post, new { @class = "form-inline" }))
{
    @Html.AntiForgeryToken()
    <select name="userId" class="form-control" style="width:auto;display:inline-block;margin-right:0.5rem;">
        @if (allUsers != null)
        {
            foreach (var u in allUsers)
            {
                <option value="@u.Id">@u.Username - @u.DisplayName</option>
            }
        }
    </select>
    <select name="accessLevel" class="form-control" style="width:auto;display:inline-block;margin-right:0.5rem;">
        <option value="Read">Read</option>
        <option value="Edit">Edit</option>
    </select>
    <button type="submit" class="btn btn-primary btn-sm">Grant</button>
}

<hr />

<h3>Group Access</h3>
@if (bookGroups != null)
{
    <table class="table table-sm">
        <thead><tr><th>Group</th><th>Level</th><th>Granted</th><th></th></tr></thead>
        <tbody>
            @foreach (var bg in bookGroups)
            {
                <tr>
                    <td>@bg.Name</td>
                    <td>@bg.AccessLevel</td>
                    <td>@bg.GrantedAt.ToString("MMM d, yyyy")</td>
                    <td>
                        @using (Html.BeginForm("RevokeGroupAccess", "BookProject", new { id = Model.BookProjectID, bookGroupId = bg.BookGroupId }, FormMethod.Post, new { style = "display:inline" }))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger btn-xs">Revoke</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<h4>Grant Group Access</h4>
@using (Html.BeginForm("GrantGroupAccess", "BookProject", new { id = Model.BookProjectID }, FormMethod.Post, new { @class = "form-inline" }))
{
    @Html.AntiForgeryToken()
    <select name="groupId" class="form-control" style="width:auto;display:inline-block;margin-right:0.5rem;">
        @if (allGroups != null)
        {
            foreach (var g in allGroups)
            {
                <option value="@g.Id">@g.Name</option>
            }
        }
    </select>
    <select name="accessLevel" class="form-control" style="width:auto;display:inline-block;margin-right:0.5rem;">
        <option value="Read">Read</option>
        <option value="Edit">Edit</option>
    </select>
    <button type="submit" class="btn btn-primary btn-sm">Grant</button>
}

<hr />

<div class="project-info">
    <p><strong>Created:</strong> @Model.CreatedDate.ToString("MMM d, yyyy h:mm tt")</p>
    <p><strong>Last Modified:</strong> @Model.LastModifiedDate.ToString("MMM d, yyyy h:mm tt")</p>
    <p><strong>Folder:</strong> @Model.FolderPath</p>
</div>
