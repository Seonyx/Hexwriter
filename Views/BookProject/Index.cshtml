@model HexWriter.Web.Models.ViewModels.BookEditor.BookProjectListViewModel
@using System.Web
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Book Editor - Projects";
    bool isAdmin = ViewBag.IsAdmin == true;
}

@section Styles {
    <link href="~/Content/css/book-editor.css" rel="stylesheet" />
}

<div class="page-header">
    <h1>@Strings.BookProject_Title</h1>
    @if (isAdmin)
    {
        <a href="@Url.Action("Create")" class="btn btn-primary">@Strings.Btn_CreateNewProject</a>
    }
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (Model.Projects.Count == 0)
{
    <div class="empty-state">
        <p>@Strings.BookProject_NoProjects@(isAdmin ? " " + Strings.BookProject_CreateFirst : "")</p>
    </div>
}
else
{
    <div class="project-grid">
        @foreach (var project in Model.Projects)
        {
            bool canEdit = isAdmin || project.AccessLevel == "Edit";
            <div class="project-card">
                <div class="project-card-cover">
                    @if (!string.IsNullOrEmpty(project.CoverImagePath) && System.IO.File.Exists(project.CoverImagePath))
                    {
                        <img src="@Url.Action("CoverThumbnail", "BookProject", new { id = project.BookProjectID })" alt="@project.ProjectName cover" />
                    }
                    else
                    {
                        <div class="project-card-placeholder">
                            <span>@Strings.BookProject_NoCover</span>
                        </div>
                    }
                </div>
                <div class="project-card-body">
                    <h3>@project.ProjectName</h3>
                    @if (!isAdmin)
                    {
                        <span class="badge @(project.AccessLevel == "Edit" ? "badge-success" : "badge-secondary")">
                            @(project.AccessLevel == "Edit" ? Strings.Badge_Editor : Strings.Badge_ReadOnly)
                        </span>
                    }
                    <p class="project-stats">
                        @project.TotalChapters @(project.TotalChapters != 1 ? Strings.Label_Chapters : Strings.Label_Chapter) &bull;
                        @project.TotalParagraphs @(project.TotalParagraphs != 1 ? Strings.Label_Paragraphs : Strings.Label_Paragraph)
                    </p>
                    <p class="project-date">
                        @Strings.Label_LastModified @project.LastModifiedDate.ToString("MMM d, yyyy h:mm tt")
                    </p>
                </div>
                <div class="project-card-actions">
                    @if (project.TotalParagraphs > 0)
                    {
                        <a href="@Url.Action("Index", "Editor", new { projectId = project.BookProjectID })" class="btn btn-primary btn-sm">@Strings.Btn_OpenEditor</a>
                    }
                    @if (canEdit)
                    {
                        <a href="@Url.Action("Index", "FileUpload", new { projectId = project.BookProjectID })" class="btn btn-secondary btn-sm">@Strings.Btn_ManageFiles</a>
                    }
                    @if (isAdmin)
                    {
                        <a href="@Url.Action("Edit", new { id = project.BookProjectID })" class="btn btn-secondary btn-sm">@Strings.Btn_Edit</a>
                    }
                    @if (project.TotalParagraphs > 0)
                    {
                        <a href="@Url.Action("Index", "Export", new { projectId = project.BookProjectID })" class="btn btn-secondary btn-sm">@Strings.Btn_Export</a>
                    }
                    @if (project.CurrentDraftNumber >= 1)
                    {
                        <a href="@Url.Action("Index", "Draft", new { projectId = project.BookProjectID })" class="btn btn-secondary btn-sm">@Strings.Btn_ManageDrafts</a>
                    }
                    @if (project.CurrentDraftNumber >= 2)
                    {
                        <a href="@Url.Action("Diff", "Draft", new { projectId = project.BookProjectID })" class="btn btn-secondary btn-sm">@Strings.Btn_CompareDrafts</a>
                    }
                    @if (isAdmin)
                    {
                        @{var confirmMsg = HttpUtility.JavaScriptStringEncode(Strings.Confirm_DeleteProject);}
                        using (Html.BeginForm("Delete", "BookProject", new { id = project.BookProjectID }, FormMethod.Post, new { style = "display:inline", onsubmit = "return confirm('" + confirmMsg + "');" }))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger btn-sm">@Strings.Btn_Delete</button>
                        }
                    }
                </div>
            </div>
        }
    </div>
}
