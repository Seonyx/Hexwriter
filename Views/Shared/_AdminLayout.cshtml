@using HexWriter.Web.Helpers
@{
    var layoutUser = AuthHelper.GetCurrentUser(new HttpContextWrapper(HttpContext.Current));
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - HexWriter Admin</title>
    <link rel="icon" href="~/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="~/favicon.ico" sizes="48x48" />
    <link rel="apple-touch-icon" href="~/apple-touch-icon.png" />
    <link rel="manifest" href="~/site.webmanifest" />
    <meta name="theme-color" content="#232046" />
    <meta property="og:title" content="Hexwriter — the long-form book editor" />
    <meta property="og:image" content="~/Content/images/social/og-image-1200x630.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@600&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="~/Content/css/site.css" rel="stylesheet" />
    <link href="~/Content/css/admin.css" rel="stylesheet" />
    @RenderSection("Styles", required: false)
</head>
<body class="admin-body">
    <header class="admin-header">
        <div class="container">
            <a href="/admin" class="admin-brand">
                <img src="~/Content/images/hexwriter-lockup-reversed.svg" alt="Hexwriter" />
            </a>
            <nav class="admin-nav">
                <a href="/admin">Dashboard</a>
                <a href="/admin/bookeditor/projects">Book Editor</a>
                @if (layoutUser != null && layoutUser.IsAdmin)
                {
                    <a href="/admin/users">Users</a>
                    <a href="/admin/groups">Groups</a>
                    <a href="/admin/settings">Settings</a>
                }
                <a href="/account/logout" class="btn-logout">Logout</a>
            </nav>
        </div>
    </header>

    <main class="admin-content">
        <div class="container">
            @if (TempData["Message"] != null)
            {
                <div class="alert alert-success">@TempData["Message"]</div>
            }
            @RenderBody()
        </div>
    </main>

    <script src="~/Scripts/site.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
