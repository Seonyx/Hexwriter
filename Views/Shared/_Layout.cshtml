@{
    var pageTitle = (ViewBag.Title != null) ? (string)ViewBag.Title : "Hexwriter";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle</title>
    @if (ViewBag.MetaDescription != null)
    {
        <meta name="description" content="@ViewBag.MetaDescription" />
    }
    <meta property="og:title" content="@pageTitle" />
    @if (ViewBag.MetaDescription != null)
    {
        <meta property="og:description" content="@ViewBag.MetaDescription" />
    }
    <meta property="og:image" content="/Content/images/social/og-image-1200x630.png" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href="~/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="~/favicon.ico" sizes="48x48" />
    <link rel="apple-touch-icon" href="~/apple-touch-icon.png" />
    <link rel="manifest" href="~/site.webmanifest" />
    <meta name="theme-color" content="#232046" />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@600&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="~/Content/css/site.css" rel="stylesheet" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <header class="site-header">
        <nav class="navbar">
            <div class="container">
                <a href="/" class="navbar-brand">
                    <img src="~/Content/images/hexwriter-lockup.svg" alt="Hexwriter" height="36" />
                </a>
                <a href="/account/login" class="btn btn-primary btn-sm">Sign In</a>
            </div>
        </nav>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="hw-footer">
        <div class="container">
            <div class="hw-footer__inner">
                <p>&copy; @DateTime.Now.Year Hexwriter. All rights reserved.</p>
                <a href="/account/login">Sign In</a>
            </div>
        </div>
    </footer>

    <script src="~/Scripts/site.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
