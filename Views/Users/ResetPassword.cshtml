@model HexWriter.Web.Models.ViewModels.Admin.ResetPasswordViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Reset Password — " + Model.Username;
}

<div class="page-header">
    <h1>Reset Password: @Model.Username</h1>
    <a href="@Url.Action("Index")" class="btn btn-secondary">Back</a>
</div>

@using (Html.BeginForm("ResetPassword", "Users", FormMethod.Post, new { @class = "admin-form" }))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.Id)
    @Html.HiddenFor(m => m.Username)
    @Html.ValidationSummary(true, "", new { @class = "alert alert-error" })

    <div class="form-group">
        @Html.LabelFor(m => m.NewPassword)
        @Html.PasswordFor(m => m.NewPassword, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.NewPassword, "", new { @class = "text-danger" })
    </div>
    <div class="form-actions">
        <button type="submit" class="btn btn-primary">Set Password</button>
        <a href="@Url.Action("Index")" class="btn btn-secondary">Cancel</a>
    </div>
}
